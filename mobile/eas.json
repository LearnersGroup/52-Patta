{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://staging.52patta.in/api",
        "EXPO_PUBLIC_WS_URL": "https://staging.52patta.in"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://52patta.in/api",
        "EXPO_PUBLIC_WS_URL": "https://52patta.in"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "0"
      }
    }
  }
}
