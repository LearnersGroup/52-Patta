{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "store",
      "prebuildCommand": "bash scripts/prebuild-ios.sh",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://staging.52patta.in/api",
        "EXPO_PUBLIC_WS_URL": "https://staging.52patta.in"
      }
    },
    "production": {
      "prebuildCommand": "bash scripts/prebuild-ios.sh",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://52patta.in/api",
        "EXPO_PUBLIC_WS_URL": "https://52patta.in"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "ascAppId": "0",
        "groups": ["Internal Testers"]
      },
      "android": {
        "serviceAccountKeyPath": "/tmp/play-service-account.json",
        "track": "internal"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "0"
      },
      "android": {
        "serviceAccountKeyPath": "/tmp/play-service-account.json",
        "track": "production"
      }
    }
  }
}
