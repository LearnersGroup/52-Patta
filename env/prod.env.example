# Production Environment
# Copy to prod.env and fill in real values
# NEVER commit prod.env to git
NODE_ENV=production
PORT=4000

# MongoDB - full Atlas connection string (includes db name, user, password)
MONGO_HOST=mongodb+srv://username:password@cluster.mongodb.net/52patta

# Auth - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_prod_jwt_secret

# CORS - production frontend URL
CORS_ORIGINS=https://yourdomain.com

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/oauth/google/callback
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=https://yourdomain.com/api/oauth/facebook/callback

# Client URL (post-login redirect target)
CLIENT_URL=https://yourdomain.com

# Sentry
# SENTRY_DSN=https://your-sentry-dsn
