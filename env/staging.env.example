# Staging Environment
# Copy to staging.env and fill in real values
NODE_ENV=staging
PORT=4000

# MongoDB - full Atlas connection string (includes db name, user, password)
MONGO_HOST=mongodb+srv://username:password@cluster.mongodb.net/52patta-staging

# Auth - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_staging_jwt_secret

# CORS - staging frontend URL
CORS_ORIGINS=https://staging.yourdomain.com

# Sentry (optional)
# SENTRY_DSN=https://your-sentry-dsn
